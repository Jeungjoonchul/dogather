<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
 PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
 "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
 <mapper namespace="User">
	<select id="checkEmail" parameterType="string" resultType="_int">
		select count(*) from t_user where user_email=#{user_email}
	</select>
	<insert id="insertUser" parameterType="UserDTO">
		insert into t_user(user_email,user_nickname,user_name,user_password,user_phone,user_gender,user_birth_date,
		user_interest,user_intro) 
		values(#{user_email},#{user_nickname},#{user_name},#{user_password},#{user_phone},#{user_gender},#{user_birth_date},#{user_interest},#{user_intro})
	</insert>
	<select id="selectUser" parameterType="string" resultType="UserDTO">
		select * from t_user where user_email #{user_email}
	</select>
	
	
	
	<insert id="insertUserTermsAgreement" parameterType="UserDTO">
		insert into t_user_terms_agreement(user_index,user_term_selective1,user_term_selective2) 
		values(#{user_index},#{user_term_selective1},#{user_term_selective2}) 
	</insert>
	<insert id="insertUserInfo" parameterType="UserDTO">
		insert into t_user(user_index) values(#{user_index})
	</insert>
	
	<insert id="insertUserAddress" parameterType="UserDTO">
		insert into t_user_address values(#{user_index},#{zip_code},#{address1},#{address2},#{address3},#{address4},#{address_detail},#{address_extra})
	</insert>
 </mapper>